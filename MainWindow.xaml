<Window x:Class="LeverageCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LeverageCalculator"
        xmlns:viewmodels="clr-namespace:LeverageCalculator.ViewModels"
        xmlns:models="clr-namespace:LeverageCalculator.Models"
        xmlns:converters="clr-namespace:LeverageCalculator.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel, IsDesignTimeCreatable=True}"
        Title="2317forever 股票期貨庫存追蹤器" Height="850" Width="1400">
    <Window.Resources>
        <!-- Global Styles -->
        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="#FFFDFDFD"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="BorderBrush" Value="#FFAAAAAA"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE0E0E0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8F8F8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFF0F0F0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#FFFFE8E8" BorderBrush="#FFEE6666" BorderThickness="1" CornerRadius="10" Width="20" Height="20">
                            <TextBlock Text="X" FontSize="10" FontWeight="Bold" Foreground="#FFCC3333" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="icon"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFF4444"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCC0000"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFCC0000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF990000"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group Card Delete Button -->
        <Style x:Key="GroupDeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="9" Width="18" Height="18">
                            <TextBlock Text="X" FontSize="9" FontWeight="Bold" Foreground="#FF999999" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="icon"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFF4444"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="450"/>
            <ColumnDefinition Width="3*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: 總市值橫幅 (跨兩欄) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FFFFF8DC" BorderBrush="#FFD4A574" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="總市值: " FontSize="22" FontWeight="ExtraBold"/>
                <TextBlock Text="{Binding TotalFuturesExposureInWan}" FontSize="22" FontWeight="ExtraBold" Foreground="DarkRed" Margin="0,0,30,0"/>
                <TextBlock Text="總口數: " FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalLots, StringFormat={}{0:N0} 口}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 左欄：期貨庫存列表 -->
        <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">

            <!-- 新增區 (Top) -->
            <GroupBox DockPanel.Dock="Top" Header="新增股票期貨" Padding="5" PreviewKeyDown="AddFutureArea_PreviewKeyDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Row 0: 股票代號 + 月份 + 口數 -->
                    <TextBlock Text="股票代號:" Margin="3,2" FontWeight="Bold" FontSize="13"/>
                    <TextBox Grid.Column="1" Text="{Binding NewUnderlyingStockCode, UpdateSourceTrigger=PropertyChanged}" Margin="3,2" x:Name="StockCodeTextBox"/>
                    <TextBlock Grid.Column="2" Text="年:" Margin="3,2" FontWeight="Bold" FontSize="13"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="3,2">
                        <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding NewContractYear}" Width="55" FontSize="12" VerticalContentAlignment="Center"/>
                        <TextBlock Text="月:" Margin="8,0,3,0" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding NewContractMonthNum}" Width="55" FontSize="12" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="4" Text="口數:" Margin="3,2" FontWeight="Bold" FontSize="13"/>
                    <TextBox Grid.Column="5" Text="{Binding NewFutureLots, UpdateSourceTrigger=PropertyChanged}" Margin="3,2"/>
                    <!-- Row 1: 大小型 + 多空 + 新增按鈕 -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="3,2">
                        <RadioButton Content="大型" FontWeight="Bold" FontSize="13" IsChecked="{Binding NewFutureIsSmallContract, Converter={StaticResource BooleanRadioConverter}, ConverterParameter=False}" Margin="5,0"/>
                        <RadioButton Content="小型" FontWeight="Bold" FontSize="13" IsChecked="{Binding NewFutureIsSmallContract, Converter={StaticResource BooleanRadioConverter}, ConverterParameter=True}" Margin="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="3,2">
                        <RadioButton Content="多單" FontWeight="Bold" FontSize="13" IsChecked="{Binding NewFuturePosition, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PositionType.Long}}" Margin="5,0"/>
                        <RadioButton Content="空單" FontWeight="Bold" FontSize="13" IsChecked="{Binding NewFuturePosition, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PositionType.Short}}" Margin="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="3,2">
                        <Button Content="新增股票期貨" Command="{Binding AddFutureCommand}"/>
                        <Button Content="批次匯入" Click="BatchImportButton_Click" Background="#FFE8F5E9" BorderBrush="#FF81C784"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 底部：摘要 + 更新按鈕 -->
            <StackPanel DockPanel.Dock="Bottom" Margin="5,5,5,0">
                <Border Background="#FFF0F8FF" BorderBrush="#FFADD8E6" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="期貨總市值: " FontWeight="ExtraBold" FontSize="16"/>
                        <TextBlock Text="{Binding TotalFuturesExposureInWan}" FontWeight="ExtraBold" FontSize="16" Foreground="DarkRed" Margin="0,0,20,0"/>
                        <TextBlock Text="總口數: " FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding TotalLots, StringFormat={}{0:N0} 口}" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="更新所有收盤價" Command="{Binding FetchAllPricesCommand}" Height="32" FontSize="13" Padding="20,4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdatingPrices}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding PriceUpdateStatus}" Margin="5,3,5,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- DataGrid：所有期貨（合併大小型） -->
            <DataGrid ItemsSource="{Binding AllFutures}" AutoGenerateColumns="False" CanUserAddRows="False"
                      ColumnWidth="*" HorizontalScrollBarVisibility="Disabled" Margin="5"
                      x:Name="FuturesDataGrid"
                      PreviewMouseLeftButtonDown="FuturesDataGrid_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="FuturesDataGrid_PreviewMouseMove">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="名稱" Binding="{Binding Name}" ElementStyle="{StaticResource CenterAlignedCellStyle}" Width="1.5*"/>
                    <DataGridTextColumn Header="股票代號" Binding="{Binding UnderlyingStockCode}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                    <DataGridTextColumn Header="類型" Binding="{Binding ContractTypeDisplay}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}" Width="0.6*"/>
                    <DataGridTextColumn Header="口數" Binding="{Binding Lots, StringFormat=N0}" ElementStyle="{StaticResource CenterAlignedCellStyle}" Width="0.6*"/>
                    <DataGridTextColumn Header="方向" Binding="{Binding PositionDisplay}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}" Width="0.5*"/>
                    <DataGridTextColumn Header="市價" Binding="{Binding CurrentPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                    <DataGridTextColumn Header="市值" Binding="{Binding ExposureInWan}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}" Width="1.2*"/>
                    <DataGridTemplateColumn Header="刪除" Width="38" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource DeleteButtonStyle}" Command="{Binding DataContext.DeleteFutureCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- 右欄：分群摘要報告 -->
        <DockPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">

            <!-- 新增群組 (Top) -->
            <GroupBox DockPanel.Dock="Top" Header="群組管理" Padding="5" PreviewKeyDown="GroupNameArea_PreviewKeyDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="群組名稱:" Margin="3,2"/>
                    <TextBox Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="3,2" x:Name="GroupNameTextBox"/>
                    <Button Content="新增群組" Command="{Binding CreateGroupCommand}" Margin="3,2"/>
                </StackPanel>
            </GroupBox>

            <!-- 底部：全部總市值 -->
            <Border DockPanel.Dock="Bottom" Background="#FFFFF8DC" BorderBrush="#FFD4A574" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5,5,5,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="全部總市值" FontSize="16" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalFuturesExposureInWan}" FontSize="28" FontWeight="ExtraBold" Foreground="DarkRed" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- 分群列表 + 未分群 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                <StackPanel>
                    <!-- 各群組卡片 (WrapPanel 自動換行排列) -->
                    <ItemsControl ItemsSource="{Binding FutureGroups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF5F5FF" BorderBrush="#FFB0B0E0" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,8,8"
                                        AllowDrop="True" Drop="GroupCard_Drop" DragOver="GroupCard_DragOver"
                                        Tag="{Binding GroupName}" MinWidth="180">
                                    <StackPanel>
                                        <!-- 群組標題列 -->
                                        <DockPanel Margin="0,0,0,3">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource GroupDeleteButtonStyle}"
                                                    Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" ToolTip="刪除群組"/>
                                            <TextBlock Text="{Binding GroupName}" FontSize="14" FontWeight="ExtraBold" Foreground="#FF4444AA"/>
                                        </DockPanel>
                                        <!-- 群組摘要 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="{Binding TotalExposureInWan}" FontWeight="Bold" FontSize="13" Foreground="DarkRed" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding TotalLots, StringFormat={}{0:N0} 口}" FontWeight="Bold" FontSize="12" Foreground="#FF666666"/>
                                        </StackPanel>
                                        <Separator Margin="0,2"/>
                                        <!-- 群組內各項目 -->
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="1,1">
                                                        <Button DockPanel.Dock="Right" Style="{StaticResource GroupDeleteButtonStyle}"
                                                                Command="{Binding DataContext.RemoveFromGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" ToolTip="移出群組"/>
                                                        <TextBlock FontSize="11" FontWeight="Normal">
                                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                                            <Run Text="(" Foreground="Gray"/><Run Text="{Binding ContractTypeDisplay, Mode=OneWay}" Foreground="Gray"/><Run Text=")" Foreground="Gray"/>
                                                            <Run Text=" "/>
                                                            <Run Text="{Binding Lots, Mode=OneWay, StringFormat=N0}" FontWeight="SemiBold"/>
                                                            <Run Text="口 "/>
                                                            <Run Text="{Binding ExposureInWan, Mode=OneWay}" Foreground="DarkRed" FontWeight="SemiBold"/>
                                                        </TextBlock>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 未分群區域 -->
                    <Border Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,8"
                            AllowDrop="True" Drop="UngroupedArea_Drop" DragOver="GroupCard_DragOver"
                            Tag="">
                        <StackPanel>
                            <TextBlock Text="[未分群]" FontSize="14" FontWeight="ExtraBold" Foreground="#FF888888" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding UngroupedFutures}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="3,2">
                                            <!-- 右側：群組下拉選單 -->
                                            <ComboBox DockPanel.Dock="Right"
                                                      ItemsSource="{Binding DataContext.FutureGroups, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="GroupName"
                                                      SelectionChanged="GroupComboBox_SelectionChanged"
                                                      Width="90" Height="22" FontSize="11" Margin="5,0,0,0"
                                                      VerticalContentAlignment="Center"/>
                                            <!-- 左側：項目資訊 -->
                                            <TextBlock FontSize="12" FontWeight="Normal" VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                <Run Text="(" Foreground="Gray"/><Run Text="{Binding ContractTypeDisplay, Mode=OneWay}" Foreground="Gray"/><Run Text=")" Foreground="Gray"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Lots, Mode=OneWay, StringFormat=N0}" FontWeight="SemiBold"/>
                                                <Run Text="口  "/>
                                                <Run Text="{Binding ExposureInWan, Mode=OneWay}" Foreground="DarkRed" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
