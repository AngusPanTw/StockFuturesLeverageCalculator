<Window x:Class="LeverageCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LeverageCalculator"
        xmlns:viewmodels="clr-namespace:LeverageCalculator.ViewModels"
        xmlns:models="clr-namespace:LeverageCalculator.Models"
        xmlns:converters="clr-namespace:LeverageCalculator.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel, IsDesignTimeCreatable=True}"
        Title="投資組合槓桿計算機 v2.0 (WPF)" Height="800" Width="1600">
    <Window.Resources>
        <!-- Global Styles for UI Beautification -->
        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="#FFFDFDFD"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="BorderBrush" Value="#FFAAAAAA"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE0E0E0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8F8F8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFF0F0F0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#FFFFE8E8" BorderBrush="#FFEE6666" BorderThickness="1" CornerRadius="10" Width="20" Height="20">
                            <TextBlock Text="X" FontSize="10" FontWeight="Bold" Foreground="#FFCC3333" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="icon"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFF4444"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCC0000"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFCC0000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF990000"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="400"/>
            <ColumnDefinition Width="2*" MinWidth="400"/>
            <ColumnDefinition Width="1*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0, Col 0: 總資產 + 更新收盤價 -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <GroupBox Header="總資產" Padding="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="可用現金:" VerticalAlignment="Center" Margin="3,2"/>
                    <TextBox Grid.Column="1" Text="{Binding BankCash, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Margin="3,2"/>
                    <TextBlock Grid.Column="2" Text="交割款:" VerticalAlignment="Center" Margin="3,2"/>
                    <TextBox Grid.Column="3" Text="{Binding StockSettlementAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Margin="3,2"/>
                    <TextBlock Grid.Column="4" Text="權益金:" VerticalAlignment="Center" Margin="3,2"/>
                    <TextBox Grid.Column="5" Text="{Binding FuturesEquity, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Margin="3,2"/>
                </Grid>
            </GroupBox>
            <StackPanel Margin="5,5,5,0">
                <Button Content="更新所有收盤價" Command="{Binding FetchAllPricesCommand}" Height="32" FontSize="13">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUpdatingPrices}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="{Binding PriceUpdateStatus}" Margin="5,5,5,0" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="Black"/>
            </StackPanel>
        </StackPanel>

        <!-- Row 0, Col 1: 公式說明 -->
        <GroupBox Grid.Row="0" Grid.Column="1" Header="公式說明" Padding="10" Margin="10,0,0,0" Background="Transparent">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="總曝險 = 股票總市值 + 期貨總市值" FontSize="14" FontWeight="SemiBold" Margin="0,4"/>
                <TextBlock Text="淨資產 = 現股市值 + 融資自備款 + 融資損益 + 可用資金 + 交割款 + 期貨權益金" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4"/>
                <TextBlock Text="槓桿倍數 = 總曝險 / 淨資產" FontSize="14" FontWeight="SemiBold" Margin="0,4"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 1, Col 0: 股票庫存 -->
        <GroupBox Grid.Row="1" Grid.Column="0" Header="股票庫存" Margin="0,5,10,0" Padding="5">
                <DockPanel>
                    <GroupBox DockPanel.Dock="Bottom" Header="新增股票" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Row 0: 代號 + 名稱 -->
                            <TextBlock Text="代號:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Grid.Column="1" Text="{Binding NewStockCode, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                            <TextBlock Grid.Column="2" Text="名稱:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Grid.Column="3" Text="{Binding NewStockName, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                            <!-- Row 1: 類型 + 股數 -->
                            <TextBlock Grid.Row="1" Text="類型:" VerticalAlignment="Center" Margin="2"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="現股" IsChecked="{Binding NewStockType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:StockType.Cash}}" Margin="5,0"/>
                                <RadioButton Content="融資" IsChecked="{Binding NewStockType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:StockType.Margin}}" Margin="5,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="股數:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding NewStockShares}" Margin="2"/>
                            <!-- Row 2: 進場均價 + 現價 -->
                            <TextBlock Grid.Row="2" Text="均價:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewStockEntryPrice}" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="現價:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding NewStockCurrentPrice}" Margin="2"/>
                            <!-- Row 3: 融資成數 + 新增按鈕 -->
                            <TextBlock Grid.Row="3" Text="融資成數:" VerticalAlignment="Center" Margin="2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewStockType}" Value="Cash">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding NewStockMarginRatio}" Margin="2">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewStockType}" Value="Cash">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Content="新增股票" Command="{Binding AddStockCommand}" Margin="3,2"/>
                        </Grid>
                    </GroupBox>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3*"/>
                            <RowDefinition Height="2*"/>
                        </Grid.RowDefinitions>

                        <!-- 現股 -->
                        <GroupBox Header="現股" Margin="0,0,0,5">
                            <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#FFF0F8FF" BorderBrush="#FFADD8E6" BorderThickness="1" CornerRadius="3" Padding="4" Margin="0,0,0,3">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="現股損益: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding CashStockProfitLoss, StringFormat={}{0:N0}}" Foreground="{Binding CashStockProfitLossColor}" FontWeight="Bold" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="報酬率: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding CashStockProfitLossPercentage, StringFormat=P2}" Foreground="{Binding CashStockProfitLossColor}" FontWeight="Bold" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding CashStocks}" AutoGenerateColumns="False" CanUserAddRows="False" ColumnWidth="*" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="代號" Binding="{Binding StockCode}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="名稱" Binding="{Binding Name}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="股數" Binding="{Binding Shares, StringFormat=N0}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="均價" Binding="{Binding EntryPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="現價" Binding="{Binding CurrentPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="市值" Binding="{Binding MarketValue, StringFormat={}{0:#,##0}}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTemplateColumn Header="損益" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProfitLoss, StringFormat={}{0:#,##0}}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="報酬率" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProfitLossPercentage, StringFormat=P2}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="刪除" Width="38" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource DeleteButtonStyle}" Command="{Binding DataContext.DeleteStockCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <!-- 融資 -->
                        <GroupBox Grid.Row="1" Header="融資" Margin="0,5,0,0">
                            <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#FFFFF0F0" BorderBrush="#FFFFB6C1" BorderThickness="1" CornerRadius="3" Padding="4" Margin="0,0,0,3">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="融資自備款: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding TotalMarginSelfFunded, StringFormat={}{0:N0}}" FontWeight="Bold" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="融資損益: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding TotalMarginProfitLoss, StringFormat={}{0:N0}}" Foreground="{Binding TotalMarginProfitLossColor}" FontWeight="Bold" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="報酬率: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding TotalMarginProfitLossPercentage, StringFormat=P2}" Foreground="{Binding TotalMarginProfitLossColor}" FontWeight="Bold" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding MarginStocks}" AutoGenerateColumns="False" CanUserAddRows="False" ColumnWidth="*" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="代號" Binding="{Binding StockCode}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="名稱" Binding="{Binding Name}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="股數" Binding="{Binding Shares, StringFormat=N0}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="均價" Binding="{Binding EntryPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="現價" Binding="{Binding CurrentPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTextColumn Header="市值" Binding="{Binding MarketValue, StringFormat={}{0:#,##0}}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                    <DataGridTemplateColumn Header="損益" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProfitLoss, StringFormat={}{0:#,##0}}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="報酬率" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProfitLossPercentage, StringFormat=P2}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="刪除" Width="38" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource DeleteButtonStyle}" Command="{Binding DataContext.DeleteStockCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </DockPanel>
            </GroupBox>

        <!-- Row 1, Col 1: 股票期貨庫存 -->
        <GroupBox Grid.Row="1" Grid.Column="1" Header="股票期貨庫存" Padding="5" Margin="10,5,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FFF0F8FF" BorderBrush="#FFADD8E6" BorderThickness="1" CornerRadius="3" Padding="5" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="期貨總損益: " FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding TotalFuturesProfitLoss, StringFormat={}{0:N0}}" Foreground="{Binding TotalFuturesProfitLossColor}" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                        <TextBlock Text="總報酬率: " FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding TotalFuturesProfitLossPercentage, StringFormat=P2}" Foreground="{Binding TotalFuturesProfitLossColor}" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Border>

                <GroupBox DockPanel.Dock="Bottom" Header="新增股票期貨" Padding="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Row 0: 代號 + 名稱 -->
                        <TextBlock Text="代號:" VerticalAlignment="Center" Margin="2"/>
                        <TextBox Grid.Column="1" Text="{Binding NewFutureStockCode, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                        <TextBlock Grid.Column="2" Text="名稱:" VerticalAlignment="Center" Margin="2"/>
                        <TextBox Grid.Column="3" Text="{Binding NewFutureName, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                        <!-- Row 1: 口數 + 方向 -->
                        <TextBlock Grid.Row="1" Text="口數:" VerticalAlignment="Center" Margin="2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewFutureLots}" Margin="2"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="方向:" VerticalAlignment="Center" Margin="2"/>
                        <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Content="多單" IsChecked="{Binding NewFuturePosition, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PositionType.Long}}" Margin="5,0"/>
                            <RadioButton Content="空單" IsChecked="{Binding NewFuturePosition, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PositionType.Short}}" Margin="5,0"/>
                        </StackPanel>
                        <!-- Row 2: 成本 + 市價 -->
                        <TextBlock Grid.Row="2" Text="成本:" VerticalAlignment="Center" Margin="2"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewFutureCostPrice}" Margin="2"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="市價:" VerticalAlignment="Center" Margin="2"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding NewFutureCurrentPrice}" Margin="2"/>
                        <!-- Row 3: 合約類型 + 新增按鈕 -->
                        <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="小型合約 (100股/口)" IsChecked="{Binding NewFutureIsSmallContract}" VerticalAlignment="Center" Margin="5,2"/>
                        <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Content="新增股票期貨" Command="{Binding AddFutureCommand}" Margin="3,2"/>
                    </Grid>
                </GroupBox>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <GroupBox Header="大型合約 (2000股)" Margin="0,0,0,5">
                        <DataGrid ItemsSource="{Binding LargeFutures}" AutoGenerateColumns="False" CanUserAddRows="False" ColumnWidth="*" HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="代號" Binding="{Binding StockCode}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="名稱" Binding="{Binding Name}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="口數" Binding="{Binding Lots, StringFormat=N0}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="方向" Binding="{Binding Position}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="成本" Binding="{Binding CostPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="市價" Binding="{Binding CurrentPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="曝險市值" Binding="{Binding Exposure, StringFormat=N0}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTemplateColumn Header="損益" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProfitLoss, StringFormat={}{0:#,##0}}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="報酬率" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProfitLossPercentage, StringFormat=P2}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="刪除" Width="38" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource DeleteButtonStyle}" Command="{Binding DataContext.DeleteFutureCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="小型合約 (100股)" Margin="0,5,0,0">
                        <DataGrid ItemsSource="{Binding SmallFutures}" AutoGenerateColumns="False" CanUserAddRows="False" ColumnWidth="*" HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="代號" Binding="{Binding StockCode}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="名稱" Binding="{Binding Name}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="口數" Binding="{Binding Lots, StringFormat=N0}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="方向" Binding="{Binding Position}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="成本" Binding="{Binding CostPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="市價" Binding="{Binding CurrentPrice, StringFormat={}{0:#,##0.##}}" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTextColumn Header="曝險市值" Binding="{Binding Exposure, StringFormat=N0}" IsReadOnly="True" ElementStyle="{StaticResource CenterAlignedCellStyle}"/>
                                <DataGridTemplateColumn Header="損益" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProfitLoss, StringFormat={}{0:#,##0}}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="報酬率" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProfitLossPercentage, StringFormat=P2}" Style="{StaticResource CenterAlignedCellStyle}" Foreground="{Binding ProfitLossColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="刪除" Width="38" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource DeleteButtonStyle}" Command="{Binding DataContext.DeleteFutureCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </DockPanel>
        </GroupBox>

        <!-- Row 0-1, Col 2: 結算報告 (跨兩行) -->
        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="最終結算報告" Margin="10,0,0,0" Padding="10" FontWeight="Bold">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 1. 股票市值明細 -->
                    <TextBlock Text="[股票市值明細]" Margin="0,5,0,3" FontSize="17"/>
                    <Separator/>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="現股市值:" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="{Binding CashStockValue, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" FontSize="16"/>
                    </Grid>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="融資市值:" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="{Binding MarginStockValue, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" FontSize="16"/>
                    </Grid>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="股票總市值:" FontSize="16" FontWeight="ExtraBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalStockValue, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" FontSize="16" FontWeight="ExtraBold"/>
                    </Grid>

                    <!-- 2. 期貨市值明細 -->
                    <TextBlock Text="[期貨市值明細]" Margin="0,12,0,3" FontSize="17"/>
                    <Separator/>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="期貨總市值:" FontSize="16" FontWeight="ExtraBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalFuturesExposure, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" FontSize="16" FontWeight="ExtraBold"/>
                    </Grid>

                    <!-- 3. 曝險與槓桿 -->
                    <TextBlock Text="[曝險與槓桿]" Margin="0,12,0,3" FontSize="17"/>
                    <Separator/>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="總曝險 (分子):" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalExposure, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" Foreground="DarkRed" FontSize="16"/>
                    </Grid>
                    <Grid Margin="5,3">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="淨資產 (分母):" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalCapital, StringFormat={}{0:N0} 元}" HorizontalAlignment="Right" Foreground="DarkGreen" FontSize="16"/>
                    </Grid>

                    <!-- 4. 槓桿倍數 -->
                    <Border Background="LightYellow" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="總資產槓桿倍數" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Leverage, StringFormat={}{0:F2} 倍}" FontSize="36" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>
