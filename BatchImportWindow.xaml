<Window x:Class="LeverageCalculator.BatchImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批次匯入股票期貨" Height="550" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 合約月份選擇 -->
        <GroupBox Grid.Row="0" Header="合約月份" Padding="5" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="年份:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="YearComboBox" Width="70" Margin="0,0,15,0"/>
                <TextBlock Text="月份:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="MonthComboBox" Width="70"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 1: 格式說明 -->
        <Border Grid.Row="1" Background="#FFF5F5FF" BorderBrush="#FFB0B0E0" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FF333333">
                <Run FontWeight="Bold" FontSize="13">格式說明</Run><LineBreak/>
                <Run Foreground="Gray">每行一筆：</Run><Run Foreground="#FF4444AA" FontWeight="SemiBold">股票代號</Run>
                <Run Foreground="Gray">（空白鍵或 Tab）</Run><Run Foreground="#FF4444AA" FontWeight="SemiBold">口數</Run><LineBreak/>
                <Run Foreground="Gray">可只填其中一種合約類型，另一種留空即可</Run><LineBreak/>
                <Run Foreground="Gray">方向預設全部多單</Run>
            </TextBlock>
        </Border>

        <!-- Row 2: 大型/小型雙區塊 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 大型合約區塊 -->
            <GroupBox Grid.Column="0" Header="大型合約" Padding="3">
                <Grid>
                    <TextBox x:Name="LargeContractTextBox"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="14"
                             TextWrapping="NoWrap"
                             Padding="5"
                             TextChanged="LargeContractTextBox_TextChanged"/>
                    <TextBlock x:Name="LargePlaceholder" IsHitTestVisible="False"
                               FontFamily="Consolas" FontSize="14" Padding="7,7"
                               Foreground="#FFAAAAAA" FontStyle="Italic"
                               VerticalAlignment="Top"
                               Text="1303    50&#x0a;2408    20&#x0a;2337    50"/>
                </Grid>
            </GroupBox>

            <!-- 小型合約區塊 -->
            <GroupBox Grid.Column="2" Header="小型合約" Padding="3">
                <Grid>
                    <TextBox x:Name="SmallContractTextBox"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="14"
                             TextWrapping="NoWrap"
                             Padding="5"
                             TextChanged="SmallContractTextBox_TextChanged"/>
                    <TextBlock x:Name="SmallPlaceholder" IsHitTestVisible="False"
                               FontFamily="Consolas" FontSize="14" Padding="7,7"
                               Foreground="#FFAAAAAA" FontStyle="Italic"
                               VerticalAlignment="Top"
                               Text="6669    20&#x0a;3653    30"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Row 3: 解析錯誤訊息 -->
        <TextBlock Grid.Row="3" x:Name="ErrorText" Foreground="Red" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Row 4: 按鈕列 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="匯入" Width="80" Height="30" FontSize="13" FontWeight="SemiBold" Click="ImportButton_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Height="30" FontSize="13" Click="CancelButton_Click" IsCancel="True" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
