<Window x:Class="LeverageCalculator.StockBatchImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批次匯入股票" Height="550" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 格式說明 -->
        <Border Grid.Row="0" Background="#FFF5F5FF" BorderBrush="#FFB0B0E0" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FF333333">
                <Run FontWeight="Bold" FontSize="13">格式說明</Run><LineBreak/>
                <Run Foreground="Gray">每行一筆：</Run><Run Foreground="#FF4444AA" FontWeight="SemiBold">股票代號</Run>
                <Run Foreground="Gray">（空白鍵或 Tab）</Run><Run Foreground="#FF4444AA" FontWeight="SemiBold">股數</Run>
                <Run Foreground="Gray">（空白鍵或 Tab）</Run><Run Foreground="#FF4444AA" FontWeight="SemiBold">進場均價</Run><LineBreak/>
                <Run Foreground="Gray">可只填其中一種類型，另一種留空即可</Run>
            </TextBlock>
        </Border>

        <!-- Row 1: 現股/融資雙區塊 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 現股區塊 -->
            <GroupBox Grid.Column="0" Header="現股" Padding="3">
                <Grid>
                    <TextBox x:Name="CashStockTextBox"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="14"
                             TextWrapping="NoWrap"
                             Padding="5"
                             TextChanged="CashStockTextBox_TextChanged"/>
                    <TextBlock x:Name="CashPlaceholder" IsHitTestVisible="False"
                               FontFamily="Consolas" FontSize="14" Padding="7,7"
                               Foreground="#FFAAAAAA" FontStyle="Italic"
                               VerticalAlignment="Top"
                               Text="2330    5000    985&#x0a;2454    3000    1250"/>
                </Grid>
            </GroupBox>

            <!-- 融資區塊 -->
            <GroupBox Grid.Column="2" Header="融資" Padding="3">
                <Grid>
                    <TextBox x:Name="MarginStockTextBox"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="14"
                             TextWrapping="NoWrap"
                             Padding="5"
                             TextChanged="MarginStockTextBox_TextChanged"/>
                    <TextBlock x:Name="MarginPlaceholder" IsHitTestVisible="False"
                               FontFamily="Consolas" FontSize="14" Padding="7,7"
                               Foreground="#FFAAAAAA" FontStyle="Italic"
                               VerticalAlignment="Top"
                               Text="1303    10000    35.5&#x0a;2317    5000    105"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Row 2: 解析錯誤訊息 -->
        <TextBlock Grid.Row="2" x:Name="ErrorText" Foreground="Red" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Row 3: 按鈕列 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="匯入" Width="80" Height="30" FontSize="13" FontWeight="SemiBold" Click="ImportButton_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Height="30" FontSize="13" Click="CancelButton_Click" IsCancel="True" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
